      "OMP_NUM_THREADS=", repr(os.environ.get("OMP_NUM_THREADS")),
      "MKL_NUM_THREADS=", repr(os.environ.get("MKL_NUM_THREADS")),
      "OPENBLAS_NUM_THREADS=", repr(os.environ.get("OPENBLAS_NUM_THREADS")))
print("[sixway] torch.get_num_threads() =", torch.get_num_threads())
PY

