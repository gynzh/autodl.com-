python - <<'PY'
import os
import torch
n = int(os.environ.get("OMP_NUM_THREADS", "8"))
assert n > 0, n
torch.set_num_threads(n)
print("[sixway] thread env:",
      "OMP_NUM_THREADS=", repr(os.environ.get("OMP_NUM_THREADS")),
      "MKL_NUM_THREADS=", repr(os.environ.get("MKL_NUM_THREADS")),
      "OPENBLAS_NUM_THREADS=", repr(os.environ.get("OPENBLAS_NUM_THREADS")))
print("[sixway] torch.get_num_threads() =", torch.get_num_threads())
PY

cd /root/autodl-tmp/mineru-work
echo "[sixway] mode=hybrid"
echo "[sixway] pdf=/root/autodl-tmp/airag/public_dataset_a/public_dataset_upload/raw/financial_contracts/text01.pdf"
